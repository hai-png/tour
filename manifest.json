    },
    {
      "src": "/media/pwa/favicon-192x192.png",
      "sizes": "192x192",
      "type": "image/png",
      "purpose": "any"
    },
    {
      "src": "/media/pwa/favicon-512x512.png",
      "sizes": "512x512",
      "type": "image/png",
      "purpose": "any"
    }
  ],
  "categories": ["travel", "lifestyle", "utilities", "entertainment"],
  "prefer_related_applications": false,
  "shortcuts": [
    {
      "name": "Start Virtual Tour",
      "short_name": "Start Tour",
      "description": "Begin the virtual tour experience",
      "url": "/index.html?start=tour",
      "icons": [
        {
          "src": "/media/pwa/icon-192x192.png",
          "sizes": "192x192",
          "type": "image/png",
          "purpose": "any"
        }
      ]
    },
    {
      "name": "View Floor Plan",
      "short_name": "Floor Plan",
      "description": "View the property floor plan",
      "url": "/index.html?view=floorplan",
      "icons": [
        {
          "src": "/media/pwa/icon-192x192.png",
          "sizes": "192x192",
          "type": "image/png",
          "purpose": "any"
        }
      ]
    },
    {
      "name": "Open Gallery",
      "short_name": "Gallery",
      "description": "Browse property photos and videos",
      "url": "/index.html?modal=gallery",
      "icons": [
        {
          "src": "/media/pwa/icon-192x192.png",
          "sizes": "192x192",
          "type": "image/png",
          "purpose": "any"
        }
      ]
    }
  ],
  "share_target": {
    "action": "/index.html?share",
    "method": "GET",
    "enctype": "application/x-www-form-urlencoded",
    "params": {
      "title": "title",
      "text": "text",
      "url": "url"
    }
  },
  "launch_handler": {
    "client_mode": "navigate-existing"
  },
  "handle_links": "preferred",
  "edge_side_panel": {
    "preferred_width": 400
  },
  "file_handlers": [
    {
      "action": "/index.html?import",
      "accept": {
        "application/json": [".json"],
        "text/xml": [".xml"]
      },
      "icons": [
        {
          "src": "/media/pwa/icon-192x192.png",
          "sizes": "192x192"
        }
      ]
    }
  ],
  "protocol_handlers": [
    {
      "protocol": "web+tour",
      "url": "/index.html?url=%s"
    }
  ],
  "screenshots": [
    {
      "src": "/media/pwa/screenshot-desktop.png",
      "sizes": "1920x1080",
      "type": "image/png",
      "form_factor": "wide",
      "label": "Desktop Virtual Tour Experience"
    },
    {
      "src": "/media/pwa/screenshot-mobile.png",
      "sizes": "750x1334",
      "type": "image/png",
      "form_factor": "narrow",
      "label": "Mobile Virtual Tour Experience"
    }
  ],
  "related_applications": [],
  "iarc_rating_id": "",
  "display_override": ["window-controls-overlay", "standalone", "minimal-ui"]
}
